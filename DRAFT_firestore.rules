rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Primitives
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    
    // Client Validation
    function isValidClient(data) {
      return data.keys().hasAll(['name', 'phone', 'ownerId', 'status', 'createdAt', 'updatedAt'])
        && data.name is string && data.name.size() <= 200
        && data.phone is string && data.phone.size() <= 50
        && data.ownerId == request.auth.uid
        && data.status is string && data.status.size() <= 50
        && data.createdAt is string && data.createdAt.size() <= 50
        && data.updatedAt is string && data.updatedAt.size() <= 50
        && data.get('email', '') is string
        && data.get('projectName', '') is string
        && (data.get('budget', 0) is number || data.get('budget', 0) is string)
        && data.get('followUpDate', '') is string
        && data.get('meetingDate', '') is string
        && data.get('salesAgent', '') is string;
    }
    
    // Activity Validation
    function isValidActivity(data, clientId) {
      return data.keys().hasAll(['clientId', 'ownerId', 'type', 'agentName', 'createdAt'])
        && data.clientId == clientId
        && data.ownerId == request.auth.uid
        && data.type is string && data.type.size() <= 50
        && data.agentName is string && data.agentName.size() <= 100
        && data.createdAt is string && data.createdAt.size() <= 50
        && data.get('content', '') is string
        && data.get('previousStatus', '') is string
        && data.get('newStatus', '') is string
        && data.get('followUpType', '') is string
        && data.get('nextAction', '') is string
        && data.get('nextFollowUpDate', '') is string;
    }
    
    // Note Validation
    function isValidNote(data, clientId) {
      return data.keys().hasAll(['clientId', 'ownerId', 'text', 'createdAt'])
        && data.clientId == clientId
        && data.ownerId == request.auth.uid
        && data.text is string && data.text.size() <= 5000
        && data.createdAt is string && data.createdAt.size() <= 50;
    }

    match /clients/{clientId} {
      allow read: if isSignedIn() && existing().ownerId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidId(clientId)
        && isValidClient(incoming());
        // For atomic activity, we could require existsAfter, but it's okay for now.
        
      allow update: if isSignedIn() 
        && isValidId(clientId)
        && existing().ownerId == request.auth.uid
        && isValidClient(incoming())
        && incoming().ownerId == existing().ownerId
        && incoming().createdAt == existing().createdAt;
        
      allow delete: if isSignedIn() 
        && isValidId(clientId)
        && existing().ownerId == request.auth.uid;
        
      match /activities/{activityId} {
        allow read: if isSignedIn() && existing().ownerId == request.auth.uid;
        allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
        
        allow create: if isSignedIn()
          && isValidId(activityId)
          && isValidActivity(incoming(), clientId)
          && get(/databases/$(database)/documents/clients/$(clientId)).data.ownerId == request.auth.uid;
        
        // Updates to activities/notes generally shouldn't happen or only owner
        allow update: if isSignedIn()
          && isValidId(activityId)
          && existing().ownerId == request.auth.uid
          && isValidActivity(incoming(), clientId)
          && incoming().ownerId == existing().ownerId
          && incoming().createdAt == existing().createdAt;
          
        allow delete: if isSignedIn()
          && isValidId(activityId)
          && existing().ownerId == request.auth.uid;
      }
      
      match /notes/{noteId} {
        allow read: if isSignedIn() && existing().ownerId == request.auth.uid;
        allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
        
        allow create: if isSignedIn()
          && isValidId(noteId)
          && isValidNote(incoming(), clientId)
          && get(/databases/$(database)/documents/clients/$(clientId)).data.ownerId == request.auth.uid;
          
        allow update: if isSignedIn()
          && isValidId(noteId)
          && existing().ownerId == request.auth.uid
          && isValidNote(incoming(), clientId)
          && incoming().ownerId == existing().ownerId
          && incoming().createdAt == existing().createdAt;
          
        allow delete: if isSignedIn()
          && isValidId(noteId)
          && existing().ownerId == request.auth.uid;
      }
    }
  }
}
