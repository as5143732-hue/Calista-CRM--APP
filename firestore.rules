rules_version = '2';

service cloud.firestore {
  match /databases/ai-studio-a90b58db-102a-4aa9-9ea9-0be6c4d4d65c/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Primitives
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null && request.auth.token.email_verified == true; }
    function isAdmin() { return isSignedIn() && get(/databases/ai-studio-a90b58db-102a-4aa9-9ea9-0be6c4d4d65c/documents/users/$(request.auth.uid)).data.role == 'admin'; }

    // User Validation
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role', 'createdAt'])
        && data.email is string && data.email.size() <= 200
        && data.role in ['admin', 'user']
        && data.createdAt is string && data.createdAt.size() <= 100;
    }

    // AppUser Validation
    function isValidAppUser(data) {
      return data.keys().hasAll(['email', 'isActive'])
        && data.email is string && data.email.size() <= 200
        && data.isActive is bool
        && (data.get('password', '') == null || data.get('password', '') is string);
    }
    
    // Client Validation
    function isValidClient(data) {
      return data.keys().hasAll(['name', 'ownerId', 'status', 'createdAt', 'updatedAt'])
        && data.name is string && data.name.size() <= 200
        && data.ownerId == request.auth.uid
        && data.status is string && data.status.size() <= 100
        && data.createdAt is string && data.createdAt.size() <= 100
        && data.updatedAt is string && data.updatedAt.size() <= 100
        && (data.get('phone', '') == null || data.get('phone', '') is string)
        && (data.get('email', '') == null || data.get('email', '') is string)
        && (data.get('projectName', '') == null || data.get('projectName', '') is string)
        && (data.get('budget', 0) == null || data.get('budget', 0) is number || data.get('budget', 0) is string)
        && (data.get('followUpDate', '') == null || data.get('followUpDate', '') is string)
        && (data.get('meetingDate', '') == null || data.get('meetingDate', '') is string)
        && (data.get('salesAgent', '') == null || data.get('salesAgent', '') is string);
    }
    
    // Activity Validation
    function isValidActivity(data, clientId) {
      return data.keys().hasAll(['clientId', 'ownerId', 'type', 'agentName', 'createdAt'])
        && data.clientId == clientId
        && data.ownerId == request.auth.uid
        && data.type is string && data.type.size() <= 100
        && data.agentName is string && data.agentName.size() <= 200
        && data.createdAt is string && data.createdAt.size() <= 100
        && (data.get('content', '') == null || data.get('content', '') is string)
        && (data.get('previousStatus', '') == null || data.get('previousStatus', '') is string)
        && (data.get('newStatus', '') == null || data.get('newStatus', '') is string)
        && (data.get('followUpType', '') == null || data.get('followUpType', '') is string)
        && (data.get('nextAction', '') == null || data.get('nextAction', '') is string)
        && (data.get('nextFollowUpDate', '') == null || data.get('nextFollowUpDate', '') is string);
    }
    
    // Note Validation
    function isValidNote(data, clientId) {
      return data.keys().hasAll(['clientId', 'ownerId', 'text', 'createdAt'])
        && data.clientId == clientId
        && data.ownerId == request.auth.uid
        && data.text is string && data.text.size() <= 10000
        && data.createdAt is string && data.createdAt.size() <= 100;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() 
        && isValidId(userId) 
        && request.auth.uid == userId
        && isValidUser(incoming());
      allow update: if isSignedIn() 
        && isValidId(userId)
        && (request.auth.uid == userId || isAdmin())
        && isValidUser(incoming());
      allow delete: if isAdmin();
    }

    match /appUsers/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() 
        && isValidId(userId) 
        && request.auth.uid == userId
        && isValidAppUser(incoming());
      allow update: if isAdmin() || (
        isSignedIn() && 
        request.auth.uid == userId && 
        incoming().diff(existing()).affectedKeys().hasOnly(['password'])
      );
      allow delete: if isAdmin();
    }

    match /clients/{clientId} {
      allow read: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() 
        && isValidId(clientId)
        && isValidClient(incoming());
        // For atomic activity, we could require existsAfter, but it's okay for now.
        
      allow update: if isSignedIn() 
        && isValidId(clientId)
        && (existing().ownerId == request.auth.uid || isAdmin())
        && isValidClient(incoming())
        && incoming().ownerId == existing().ownerId
        && incoming().createdAt == existing().createdAt;
        
      allow delete: if isSignedIn() 
        && isValidId(clientId)
        && (existing().ownerId == request.auth.uid || isAdmin());
        
      match /activities/{activityId} {
        allow read: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
        allow list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
        
        allow create: if isSignedIn()
          && isValidId(activityId)
          && isValidActivity(incoming(), clientId)
          && (get(/databases/ai-studio-a90b58db-102a-4aa9-9ea9-0be6c4d4d65c/documents/clients/$(clientId)).data.ownerId == request.auth.uid || isAdmin());
        
        allow update: if isSignedIn()
          && isValidId(activityId)
          && (existing().ownerId == request.auth.uid || isAdmin())
          && isValidActivity(incoming(), clientId)
          && incoming().ownerId == existing().ownerId
          && incoming().createdAt == existing().createdAt;
          
        allow delete: if isSignedIn()
          && isValidId(activityId)
          && (existing().ownerId == request.auth.uid || isAdmin());
      }
      
      match /notes/{noteId} {
        allow read: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
        allow list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
        
        allow create: if isSignedIn()
          && isValidId(noteId)
          && isValidNote(incoming(), clientId)
          && (get(/databases/ai-studio-a90b58db-102a-4aa9-9ea9-0be6c4d4d65c/documents/clients/$(clientId)).data.ownerId == request.auth.uid || isAdmin());
          
        allow update: if isSignedIn()
          && isValidId(noteId)
          && (existing().ownerId == request.auth.uid || isAdmin())
          && isValidNote(incoming(), clientId)
          && incoming().ownerId == existing().ownerId
          && incoming().createdAt == existing().createdAt;
          
        allow delete: if isSignedIn()
          && isValidId(noteId)
          && (existing().ownerId == request.auth.uid || isAdmin());
      }
    }
  }
}
